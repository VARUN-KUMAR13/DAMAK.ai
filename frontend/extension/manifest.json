{
  "manifest_version": 3,
  "name": "DAMAK AI Capture",
  "version": "1.0",
  "description": "Passive AI learning capture for DAMAK AI.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "storage",
    "offscreen",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
