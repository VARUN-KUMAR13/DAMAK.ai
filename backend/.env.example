# Copy to `.env` in this folder (`backend/`) and adjust as needed.
# Do not commit real `.env` files with secrets (Phase 1 has no API keys).

APP_NAME=AI Lecture Intelligence API
LOG_LEVEL=INFO

# Repo root (folder that contains `storage/` and `backend/`). Override if auto-detection is wrong.
# PROJECT_ROOT=D:\DAMAK AI

# Optional: override default storage locations (defaults: <PROJECT_ROOT>/storage/...)
# STORAGE_UPLOADS=
# STORAGE_AUDIO=
# STORAGE_TRANSCRIPTS=
# STORAGE_SCREENSHOTS=
# STORAGE_OCR=
# STORAGE_CHUNKS=
# STORAGE_EMBEDDINGS=

WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# FFmpeg executable: must be on PATH, or set full path (Windows: e.g. C:\ffmpeg\bin\ffmpeg.exe)
FFMPEG_PATH=ffmpeg

# Screenshot extraction (Phase 2)
SCREENSHOT_INTERVAL_SEC=2.0
SCREENSHOT_SSIM_THRESHOLD=0.96
SCREENSHOT_MIN_CHANGE_RATIO=0.02
SCREENSHOT_JPEG_QUALITY=90

# OCR Processing (Phase 3)
OCR_LANG=en
OCR_USE_GPU=False
OCR_USE_ANGLE_CLS=True

# Multimodal Chunking (Phase 4)
CHUNK_MAX_WORDS=250
CHUNK_OVERLAP_SEC=2.0

# Local RAG Chat (Phase 6)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3

MAX_UPLOAD_MB=500
